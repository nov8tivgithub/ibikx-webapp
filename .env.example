# Copy to .env and fill in real values. Vite only exposes vars prefixed with VITE_.

# ─── Frontend uses this base URL for every API call ──────────────────────────
# In development with the Vite proxy, set this to "/api" — the proxy below
# will forward those requests to VITE_API_TARGET, sidestepping CORS entirely.
# In production, set this to the real backend URL.
VITE_API_URL=/api

# ─── Dev proxy target (vite.config.js) ───────────────────────────────────────
# Only used while running `npm run dev`. Leave blank in production.
VITE_API_TARGET=https://demo.icwares.com/ibikx/ideacaards/api/dev

# ─── App credentials ─────────────────────────────────────────────────────────
# apitoken inside apiInfo
VITE_API_KEY=your-app-id
# Shared device secret used by loginService to compute apiInfo.enckey:
#   enckey = md5(lowercase(email) + password + VITE_DEVICE_SECRET)
VITE_DEVICE_SECRET=3584okjn^&%&njjasd(@K

# ─── Webview base URL ────────────────────────────────────────────────────────
# Hosted pages embedded as iframes (e.g. forgotpassword). Must end with a slash.
VITE_WEBVIEW_URL=https://demo.icwares.com/ibikx/ideacaards/manage/dev/mobileapi/

# ─── Optional device descriptors (defaults shown) ────────────────────────────
# VITE_DEVICE_TOKEN=web-client
# VITE_DEVICE_KEY=web
# VITE_DEVICE_TYPE=web
# VITE_DEVICE_OS=w
# VITE_BUILD_VERSION=1.0.0
# VITE_BUILD_NUMBER=1
